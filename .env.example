# Postgres connection string (see docker-compose.yml on the VPS for the real value)
DATABASE_URL="postgresql://gativcare:password@localhost:5432/gativcare?schema=public"

# Hostinger (or any) SMTP mailbox used to send lead notification emails
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="care@gativcare.com"
SMTP_PASSWORD=""

# Random secret used to sign session cookies (generate with: openssl rand -hex 32)
AUTH_SECRET=""

# Absolute path (inside the container) where uploaded medical reports are stored
UPLOADS_DIR="/app/uploads"

# Where contact-form lead notifications get sent
ADMIN_NOTIFICATION_EMAIL="care@gativcare.com"
